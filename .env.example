# ─── Sanity CMS ───────────────────────────────────────────────────────────────
# Get these from https://sanity.io/manage → your project → API
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=          # Read-only token: Settings → API → Tokens

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Get API key from https://resend.com/api-keys
RESEND_API_KEY=
CONTACT_TO_EMAIL=                  # Your email address
RESEND_FROM_EMAIL=onboarding@resend.dev  # Use contact@yourdomain.com after domain verification
